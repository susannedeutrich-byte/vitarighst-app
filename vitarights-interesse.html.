<script>
function setView(v, btn) {
  document.querySelectorAll('.view').forEach(function(el){el.classList.remove('active');});
  document.getElementById('view-'+v).classList.add('active');
  document.querySelectorAll('.toggle-btn').forEach(function(b){b.classList.remove('active');});
  btn.classList.add('active');
}

function makeWaLink(phone, name) {
  if(!phone) return '#';
  var clean = phone.replace(/[^0-9+]/g,'');
  if(clean.startsWith('0')) clean = '+49' + clean.substring(1);
  var num = clean.replace('+','');
  var msg = encodeURIComponent('Hallo ' + (name||'') + ', ich habe deine Seite über Vitarights gesehen und möchte gerne mehr erfahren.');
  return 'https://wa.me/' + num + '?text=' + msg;
}

function getParam(name){
  try{
    var search=window.location.search.substring(1);
    var pairs=search.split('&');
    for(var i=0;i<pairs.length;i++){
      var pair=pairs[i].split('=');
      if(decodeURIComponent(pair[0])===name){
        return pair[1]?decodeURIComponent(pair[1].replace(/[+]/g,' ')):'';
      }
    }
  }catch(e){}
  return '';
}

function generateMyLink(){
  var n=document.getElementById('ob-n').value.trim();
  var t=document.getElementById('ob-t').value.trim();
  var e=document.getElementById('ob-e').value.trim();
  if(!n){alert('Bitte deinen Namen eintragen.');return;}
  var data={n:n,t:t,e:e};
  var d=btoa(unescape(encodeURIComponent(JSON.stringify(data))));
  var base=window.location.href.split('#')[0].split('?')[0];
  var link=base+'#d='+d;
  document.getElementById('ob-link-out').value=link;
  document.getElementById('ob-link-box').style.display='block';
  copyMyLink();
}
function copyMyLink(){
  var link=document.getElementById('ob-link-out').value;
  try{if(navigator.clipboard&&window.isSecureContext){navigator.clipboard.writeText(link);}}catch(ex){}
  var ta=document.createElement('textarea');ta.value=link;ta.style.position='fixed';ta.style.left='-9999px';
  document.body.appendChild(ta);ta.focus();ta.select();
  try{document.execCommand('copy');}catch(ex){}
  document.body.removeChild(ta);
  var ok=document.getElementById('ob-copy-ok');
  if(ok){ok.style.display='block';setTimeout(function(){ok.style.display='none';},3000);}
}

function initPage() {
  try {
    // Hash #d= lesen
    var bname='', bphone='', bemail='';
    var hash=window.location.hash.substring(1);
    if(hash.indexOf('d=')===0){
      try{
        var dec=JSON.parse(atob(decodeURIComponent(hash.substring(2))));
        bname=dec.n||''; bphone=dec.t||''; bemail=dec.e||'';
      }catch(ex){}
    }
    // Berater-Bereich befüllen
    if(bname){
      var bs=document.getElementById('berater-section');
      if(bs)bs.style.display='block';
      var bn=document.getElementById('b-name');
      if(bn)bn.textContent=bname;
      var av=document.getElementById('b-avatar');
      if(av){var pts=bname.trim().split(' ');av.textContent=pts.map(function(w){return w[0]||'';}).join('').substring(0,2).toUpperCase();}
      if(bphone){
        var clean=bphone.replace(/[^0-9+]/g,'');
        if(clean.startsWith('+')){}else if(clean.startsWith('00'))clean='+'+clean.substring(2);else if(clean.startsWith('0'))clean='+49'+clean.substring(1);
        var waRow=document.getElementById('b-wa-row');
        var waLink=document.getElementById('b-wa-link');
        if(waRow)waRow.style.display='block';
        if(waLink)waLink.href='https://wa.me/'+clean.replace('+','');
      }
      if(bemail){
        var eRow=document.getElementById('b-email-row');
        var eLink=document.getElementById('b-email-link');
        if(eRow)eRow.style.display='block';
        if(eLink)eLink.href='mailto:'+bemail;
      }
    } else {
      // Kein Hash → Onboarding zeigen
      var ob=document.getElementById('inte-onboarding');
      if(ob)ob.style.display='block';
    }
    // Versuche zuerst Base64 d= Parameter
    var name='', phone='', photo='';
    // Hash-Parameter #d= lesen (Netlify-sicher)
    var hash=window.location.hash.substring(1);
    var d='';
    if(hash.indexOf('d=')===0) d=hash.substring(2);
    if(d){
      try{
        var dec=JSON.parse(atob(decodeURIComponent(d)));
        name=dec.n||''; phone=dec.t||''; photo=dec.ph||'';
      }catch(ex){}
    }
    if(!name){
      name = getParam('n') || '';
      phone = getParam('t') || getParam('tel') || '';
    }
  } catch(e) {}
}







