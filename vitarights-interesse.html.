<style>
  :root {
    --navy: #1E2D5A;
    --navy-light: #2a3d7a;
    --gold: #C9A84C;
    --gold-light: #f5e9c8;
    --green: #25d366;
    --white: #ffffff;
    --beige: #F7F4EF;
    --text-dark: #1a1a2e;
    --text-mid: #4a5568;
    --text-light: #8a95a3;
    --radius: 16px;
    --radius-sm: 10px;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    background: var(--beige);
    color: var(--text-dark);
    max-width: 480px;
    margin: 0 auto;
    min-height: 100vh;
  }

  /* HERO */
  .hero {
    background: linear-gradient(160deg, var(--navy) 0%, #2d4a8a 60%, #1a3060 100%);
    padding: 48px 24px 40px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute;
    top: -60px; right: -60px;
    width: 200px; height: 200px;
    background: rgba(201,168,76,0.15);
    border-radius: 50%;
  }
  .hero-eyebrow {
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 14px;
  }
  .hero-title {
    font-size: 30px;
    font-weight: 800;
    color: var(--white);
    line-height: 1.2;
    margin-bottom: 16px;
  }
  .hero-title span { color: var(--gold); }
  .hero-sub {
    font-size: 17px;
    color: rgba(255,255,255,0.8);
    line-height: 1.6;
    margin-bottom: 28px;
  }

  /* TOGGLE */
  .toggle-wrap {
    display: flex;
    background: rgba(255,255,255,0.12);
    border-radius: 50px;
    padding: 4px;
    margin: 0 auto;
    max-width: 280px;
  }
  .toggle-btn {
    flex: 1;
    padding: 11px 16px;
    border: none;
    border-radius: 50px;
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    transition: all .2s;
    background: transparent;
    color: rgba(255,255,255,0.7);
  }
  .toggle-btn.active {
    background: var(--white);
    color: var(--navy);
  }

  /* SECTIONS */
  .section { padding: 28px 20px 0; }
  .section-label {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--text-light);
    margin-bottom: 14px;
  }

  /* INTRO KARTE */
  .intro-card {
    background: var(--white);
    border-radius: var(--radius);
    padding: 22px;
    margin-bottom: 12px;
    box-shadow: 0 2px 12px rgba(26,39,68,0.08);
  }
  .intro-card p {
    font-size: 17px;
    line-height: 1.7;
    color: var(--text-mid);
  }
  .intro-card strong { color: var(--text-dark); }

  /* THEMEN-PILLS */
  .pills {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 16px;
  }
  .pill {
    padding: 7px 14px;
    border-radius: 50px;
    background: var(--gold-light);
    color: var(--navy);
    font-size: 14px;
    font-weight: 600;
  }

  /* VIDEO */
  .video-wrap {
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: 0 4px 16px rgba(26,39,68,0.15);
    margin-bottom: 12px;
  }
  .video-wrap iframe {
    display: block;
    width: 100%;
    aspect-ratio: 16/9;
    border: none;
  }
  .video-label {
    background: var(--navy);
    color: var(--white);
    padding: 12px 16px;
    font-size: 15px;
    font-weight: 600;
  }

  /* AUSSAGEN */
  .quote-card {
    background: var(--white);
    border-radius: var(--radius);
    padding: 20px;
    margin-bottom: 10px;
    box-shadow: 0 1px 6px rgba(26,39,68,0.07);
    border-left: 4px solid var(--gold);
  }
  .quote-text {
    font-size: 16px;
    line-height: 1.7;
    color: var(--text-mid);
    font-style: italic;
  }
  .quote-text::before { content: '„'; color: var(--gold); font-size: 20px; font-style: normal; }
  .quote-text::after { content: '"'; color: var(--gold); font-size: 20px; font-style: normal; }

  /* WIE FUNKTIONIERT ES */
